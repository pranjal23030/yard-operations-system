@* YardManager Sidebar - Limited access *@
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isDashboardActive = currentPage.Contains("/YardManager/Dashboard");

    var isIngatesActive = currentPage.Contains("/Admin/Operations/Ingates");
    var isOutgatesActive = currentPage.Contains("/Admin/Operations/Outgates");
    var isAllOperationsActive = currentPage.Contains("/Admin/Operations/AllOperations");
    var isOperationsActive = isIngatesActive || isOutgatesActive || isAllOperationsActive;

    var isTrailersActive = currentPage.Contains("Trailers");
    var isLocationsActive = currentPage.Contains("Locations");
    var isSnapshotReportActive = currentPage.Contains("/Admin/Reports/Snapshots");
}
<aside id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-brand">
            <div class="sidebar-logo-box">
                <img src="~/images/yardops-logo.png" alt="YardOps" class="sidebar-logo-img" />
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-title">YardOps</span>
                <span class="sidebar-brand-subtitle">Yard Manager</span>
            </div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <a asp-page="/YardManager/Dashboard" class="nav-item-link @(isDashboardActive ? "active" : "")">
            <i class="fa-solid fa-chart-line"></i>
            <span>Dashboard</span>
        </a>

        <div class="sidebar-group">
            <button class="nav-group-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#yardManagerOperationsGroup" aria-expanded="@(isOperationsActive ? "true" : "false")">
                <i class="fa-solid fa-wave-square"></i>
                <span>Operations</span>
                <i class="fa-solid fa-chevron-down group-caret"></i>
            </button>
            <div class="collapse @(isOperationsActive ? "show" : "") nav-group" id="yardManagerOperationsGroup">
                <a asp-page="/Admin/Operations/Ingates/Index" class="nav-item-link nav-subitem @(isIngatesActive ? "active" : "")">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Ingates</span>
                </a>
                <a asp-page="/Admin/Operations/Outgates/Index" class="nav-item-link nav-subitem @(isOutgatesActive ? "active" : "")">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Outgates</span>
                </a>
                <a asp-page="/Admin/Operations/AllOperations/Index" class="nav-item-link nav-subitem @(isAllOperationsActive ? "active" : "")">
                    <i class="fa-solid fa-list-check"></i>
                    <span>All Operations</span>
                </a>
            </div>
        </div>

        <a class="nav-item-link @(isTrailersActive ? "active" : "")"
           asp-page="/Admin/Trailers/Index">
            <i class="fa-solid fa-truck"></i>
            <span>Trailers</span>
        </a>

        <a class="nav-item-link @(isLocationsActive ? "active" : "")"
           asp-page="/Admin/Locations/Index">
            <i class="fa-solid fa-map-location-dot"></i>
            <span>Locations</span>
        </a>

        <a class="nav-item-link @(isSnapshotReportActive ? "active" : "")"
           asp-page="/Admin/Reports/Snapshots/Index">
            <i class="fa-solid fa-camera"></i>
            <span>Snapshot Report</span>
        </a>

        <a href="#" class="nav-item-link">
            <i class="fa-solid fa-eye"></i>
            <span>Monitoring</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <button class="collapse-btn sidebar-toggle-btn" id="sidebarToggle">
            <i class="fa-solid fa-angles-left" id="toggleIcon"></i>
            <span>Collapse Sidebar</span>
        </button>
    </div>
</aside>