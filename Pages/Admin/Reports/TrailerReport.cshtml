@page
@model YardOps.Pages.Admin.Reports.TrailerReportModel
@{
    ViewData["Title"] = "Trailer Report";
    ViewData["PageHeader"] = "Trailer Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
}

@if (!string.IsNullOrWhiteSpace(Model.ValidationMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@Model.ValidationMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.SearchIgnoredBecauseTooShort)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-info me-2"></i>Search is applied only when at least 3 characters are entered.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="users-header report-header">
    <h1 class="users-title">Trailer Report</h1>

    <div class="dropdown">
        <button class="btn-export dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="fa-solid fa-download me-1"></i>Export
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li>
                <a class="dropdown-item"
                   asp-page-handler="ExportPdf"
                   asp-route-SearchTerm="@Model.SearchTerm"
                   asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                   asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
                   asp-route-StatusFilter="@Model.StatusFilter"
                   asp-route-LocationFilter="@Model.LocationFilter">
                    <i class="fa-solid fa-file-pdf me-2"></i>PDF
                </a>
            </li>
        </ul>
    </div>
</div>

<form method="get" id="filterForm">
    <input type="hidden" name="PageNumber" value="1" />

    <div class="filters-row">
        <div class="search-box">
            <i class="fa-solid fa-search search-icon"></i>
            <input type="text" id="globalSearch" name="SearchTerm" value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="Search carrier, trailer, driver (min 3 chars)..." />
        </div>

        <div class="filter-dropdown-wrapper">
            <select name="StatusFilter" class="filter-select">
                @foreach (var status in Model.StatusOptions)
                {
                    var selected = Model.StatusFilter == status.Value || (string.IsNullOrWhiteSpace(Model.StatusFilter) && status.Value == "all");
                    <option value="@status.Value" selected="@selected">@status.Text</option>
                }
            </select>
        </div>

        <div class="filter-dropdown-wrapper">
            <select name="LocationFilter" class="filter-select">
                @foreach (var loc in Model.LocationOptions)
                {
                    var selected = Model.LocationFilter == loc.Value || (string.IsNullOrWhiteSpace(Model.LocationFilter) && loc.Value == "all");
                    <option value="@loc.Value" selected="@selected">@loc.Text</option>
                }
            </select>
        </div>

        <div class="filter-date-wrapper">
            <label class="filter-date-label">From</label>
            <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="filter-date" />
        </div>

        <div class="filter-date-wrapper">
            <label class="filter-date-label">To</label>
            <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="filter-date" />
        </div>

        <button type="submit" class="btn-generate-report">
            <i class="fa-solid fa-filter me-1"></i>Apply
        </button>

        <a asp-page-handler="Clear" class="btn-clear-filters">
            <i class="fa-solid fa-times me-1"></i>Clear
        </a>
    </div>
</form>

<div class="report-summary">
    <span>
        Showing data from
        <strong>@Model.StartDate?.ToString("yyyy-MM-dd")</strong>
        to
        <strong>@Model.EndDate?.ToString("yyyy-MM-dd")</strong>
    </span>
    <span>Total: <strong>@Model.TotalRows</strong> records</span>
</div>

<div class="users-table">
    <table>
        <thead>
            <tr>
                <th>Trailer Code</th>
                <th>Carrier</th>
                <th>Driver</th>
                <th>Status</th>
                <th>Location</th>
                <th>Arrival</th>
                <th>Departure</th>
                <th>Created On</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Rows.Any())
            {
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td data-label="Trailer Code">@row.TrailerCode</td>
                        <td data-label="Carrier">@row.CarrierName</td>
                        <td data-label="Driver">@row.DriverName</td>
                        <td data-label="Status">
                            <span class="status-badge status-@row.Status.ToLower().Replace(" ", "-")">@row.Status</span>
                        </td>
                        <td data-label="Location">@row.LocationName</td>
                        <td data-label="Arrival">@(row.Arrival?.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") ?? "—")</td>
                        <td data-label="Departure">@(row.Departure?.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") ?? "—")</td>
                        <td data-label="Created On">@row.CreatedOn.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-file-lines fa-3x mb-3 d-block"></i>
                        No report data found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="pagination-footer">
    <div class="pagination-info">
        @{
            var startItem = Model.TotalRows == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1;
            var endItem = Math.Min(Model.CurrentPage * 10, Model.TotalRows);
        }
        Showing @startItem to @endItem of @Model.TotalRows records
    </div>
    <div class="pagination-controls">
        @if (Model.CurrentPage > 1)
        {
            <a href="?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-left"></i></button>
        }

        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            if (i == Model.CurrentPage)
            {
                <button class="page-btn active">@i</button>
            }
            else
            {
                <a href="?PageNumber=@i&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn">@i</a>
            }
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&StartDate=@Model.StartDate?.ToString("yyyy-MM-dd")&EndDate=@Model.EndDate?.ToString("yyyy-MM-dd")&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-right"></i></button>
        }
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('globalSearch');
        const filterForm = document.getElementById('filterForm');
        let timer;

        if (searchInput && filterForm) {
            searchInput.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(() => {
                    const value = (searchInput.value || '').trim();
                    if (value.length >= 3 || value.length === 0) {
                        filterForm.submit();
                    }
                }, 400);
            });
        }
    </script>
}