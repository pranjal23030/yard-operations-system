@page
@model YardOps.Pages.Admin.Reports.Snapshots.IndexModel
@{
    ViewData["Title"] = "Snapshot Report";
    ViewData["PageHeader"] = "Snapshot Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/snapshots.css" asp-append-version="true" />
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="users-header report-header">
    <h1 class="users-title">Snapshot Report</h1>

    <div class="d-flex align-items-center gap-2">
        <div class="dropdown">
            <button class="btn-export dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="fa-solid fa-download me-1"></i>Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a class="dropdown-item"
                           asp-page-handler="ExportPdf"
                           asp-route-SelectedRunId="@Model.SelectedRunId"
                           asp-route-SearchTerm="@Model.SearchTerm">
                        <i class="fa-solid fa-file-pdf me-2"></i>PDF
                    </a>
                </li>
            </ul>
        </div>

        <button type="button" class="btn-generate-report" data-bs-toggle="modal" data-bs-target="#captureSnapshotModal">
            <i class="fa-solid fa-camera me-1"></i>Capture Snapshot
        </button>
    </div>
</div>

<form method="get" id="filterForm">
    <input type="hidden" name="PageNumber" value="1" />

    <div class="filters-row">
        <div class="filter-dropdown-wrapper">
            <select name="SelectedRunId" class="filter-select" onchange="this.form.submit()">
                @if (Model.Runs.Any())
                {
                    @foreach (var run in Model.Runs)
                    {
                        var selected = Model.SelectedRunId == run.SnapshotRunId;
                        <option value="@run.SnapshotRunId" selected="@selected">
                            Run #@run.SnapshotRunId - @run.CapturedAt.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") (@run.ItemCount)
                        </option>
                    }
                }
                else
                {
                    <option value="">No snapshots yet</option>
                }
            </select>
        </div>

        <div class="search-box">
            <i class="fa-solid fa-search search-icon"></i>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
                   placeholder="Search trailer, carrier, driver, location..." />
        </div>

        <button type="submit" class="btn-generate-report">
            <i class="fa-solid fa-filter me-1"></i>Apply
        </button>

        <a asp-page="/Admin/Reports/Snapshots/Index" class="btn-clear-filters">
            <i class="fa-solid fa-times me-1"></i>Clear
        </a>
    </div>
</form>

<div class="report-summary">
    @if (Model.Runs.Any() && Model.SelectedRunId.HasValue)
    {
        var selectedRun = Model.Runs.FirstOrDefault(r => r.SnapshotRunId == Model.SelectedRunId.Value);
        if (selectedRun != null)
        {
            <span>Selected Run: <strong>#@selectedRun.SnapshotRunId</strong> at <strong>@selectedRun.CapturedAt.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</strong></span>
            <span>Captured by: <strong>@selectedRun.CapturedBy</strong></span>
        }
    }
    else
    {
        <span>No snapshot selected</span>
        <span>Capture your first snapshot to begin</span>
    }
</div>

<div class="users-table">
    <table>
        <thead>
            <tr>
                <th>Trailer</th>
                <th>Status</th>
                <th>Carrier</th>
                <th>Driver</th>
                <th>Goods Type</th>
                <th>Location</th>
                <th>Arrival</th>
                <th>Captured At</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Any())
            {
                @foreach (var row in Model.Items)
                {
                    <tr>
                        <td data-label="Trailer">@row.TrailerCode</td>
                        <td data-label="Status">
                            <span class="status-badge status-@row.Status.ToLower().Replace(" ", "-")">@row.Status</span>
                        </td>
                        <td data-label="Carrier">@row.CarrierName</td>
                        <td data-label="Driver">@row.DriverName</td>
                        <td data-label="Goods Type">@row.GoodsType</td>
                        <td data-label="Location">@row.LocationName (@row.LocationType)</td>
                        <td data-label="Arrival">@(row.ArrivalTime?.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") ?? "—")</td>
                        <td data-label="Captured At">@row.CapturedAt.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-camera fa-3x mb-3 d-block"></i>
                        No snapshot data found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="pagination-footer">
    <div class="pagination-info">
        @{
            var startItem = Model.TotalItems == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1;
            var endItem = Math.Min(Model.CurrentPage * 10, Model.TotalItems);
        }
        Showing @startItem to @endItem of @Model.TotalItems records
    </div>
    <div class="pagination-controls">
        @if (Model.CurrentPage > 1)
        {
            <a href="?PageNumber=@(Model.CurrentPage - 1)&SelectedRunId=@Model.SelectedRunId&SearchTerm=@Model.SearchTerm" class="page-btn">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-left"></i></button>
        }

        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            if (i == Model.CurrentPage)
            {
                <button class="page-btn active">@i</button>
            }
            else
            {
                <a href="?PageNumber=@i&SelectedRunId=@Model.SelectedRunId&SearchTerm=@Model.SearchTerm" class="page-btn">@i</a>
            }
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?PageNumber=@(Model.CurrentPage + 1)&SelectedRunId=@Model.SelectedRunId&SearchTerm=@Model.SearchTerm" class="page-btn">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-right"></i></button>
        }
    </div>
</div>

<partial name="_Partials/_CaptureSnapshotModal" model="Model" />

@section Scripts {
    <partial name="_Partials/_SnapshotScripts" model="Model" />
}