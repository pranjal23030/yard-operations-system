@using YardOps.Pages.Admin.Trailers
@model IndexModel

<div class="modal fade" id="editTrailerModal" tabindex="-1" aria-labelledby="editTrailerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="editTrailerModalLabel">Edit Trailer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" asp-page-handler="Edit">
                <input type="hidden" asp-for="EditInput.TrailerId" />
                <input type="hidden" asp-for="EditGoodsJson" id="EditGoodsJson" value="[]" />

                <div class="modal-body modal-body-custom">
                    <div class="edit-code-display mb-3">
                        <span class="label">Trailer ID:</span>
                        <span class="value" id="editTrailerCodeDisplay">—</span>
                    </div>

                    <ul class="nav nav-tabs mb-3" id="editTrailerTabs" role="tablist">
                        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#edit-basic" type="button">Basic Info</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#edit-goods" type="button">Goods Manifest</button></li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="edit-basic">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="EditInput.CarrierId" class="form-label-custom">Carrier *</label>
                                    <select asp-for="EditInput.CarrierId" class="form-select-custom">
                                        @foreach (var c in Model.CarrierOptions.Where(c => c.Value != "all"))
                                        {
                                            <option value="@c.Value">@c.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditInput.DriverUserId" class="form-label-custom">Driver *</label>
                                    <select asp-for="EditInput.DriverUserId" class="form-select-custom">
                                        <option value="">Select driver</option>
                                        @foreach (var d in Model.DriverOptions)
                                        {
                                            <option value="@d.Value">@d.Text</option>
                                        }
                                    </select>
                                    <span asp-validation-for="EditInput.DriverUserId" class="validation-error-custom"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditInput.GoodsType" class="form-label-custom">Goods Type *</label>
                                    <select asp-for="EditInput.GoodsType" class="form-select-custom">
                                        @foreach (var g in Model.GoodsTypeOptions)
                                        {
                                            <option value="@g.Value">@g.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditInput.CurrentStatus" class="form-label-custom">Status *</label>
                                    <select asp-for="EditInput.CurrentStatus" class="form-select-custom">
                                        @foreach (var s in Model.StatusOptions.Where(s => s.Value != "all"))
                                        {
                                            <option value="@s.Value">@s.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EditInput.LocationId" class="form-label-custom">Location</label>
                                    <select asp-for="EditInput.LocationId" class="form-select-custom">
                                        <option value="">Not assigned</option>
                                        @foreach (var l in Model.AssignableLocationOptions.Where(l => l.Value != "all"))
                                        {
                                            <option value="@l.Value">@l.Text</option>
                                        }
                                    </select>
                                    <span asp-validation-for="EditInput.LocationId" class="validation-error-custom"></span>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="edit-goods">
                            <partial name="_Partials/_GoodsManifestBuilder" model='"Edit"' />
                        </div>
                    </div>
                </div>

                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn-cancel-neutral" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-custom">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>