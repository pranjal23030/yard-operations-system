@using YardOps.Pages.Admin.Trailers
@model IndexModel

<div class="modal fade" id="deleteTrailerModal" tabindex="-1" aria-labelledby="deleteTrailerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="deleteTrailerModalLabel">Delete Trailer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" name="trailerId" id="deleteTrailerId" />
                <div class="modal-body modal-body-custom">
                    <div class="delete-warning-icon">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                    <p class="delete-message">
                        Are you sure you want to delete trailer <strong id="deleteTrailerCode"></strong>?
                    </p>
                    <p class="delete-submessage">
                        This action cannot be undone and will remove associated goods/history/gate records.
                    </p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn-cancel-neutral" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-delete-custom">Delete Trailer</button>
                </div>
            </form>
        </div>
    </div>
</div>