@using YardOps.Pages.Admin.Trailers
@model IndexModel

<div class="modal fade" id="ingateModal" tabindex="-1" aria-labelledby="ingateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="ingateModalLabel">Ingate Trailer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" asp-page-handler="Ingate">
                <input type="hidden" asp-for="IngateInput.TrailerId" id="ingateTrailerId" />
                <div class="modal-body modal-body-custom">
                    <p class="mb-2">Trailer: <strong id="ingateTrailerCode">—</strong></p>

                    <div class="form-group-custom">
                        <label asp-for="IngateInput.LocationId" class="form-label-custom">Gate Location *</label>
                        <select asp-for="IngateInput.LocationId" class="form-select-custom">
                            <option value="">Select gate</option>
                            @foreach (var gate in Model.GateLocationOptions)
                            {
                                <option value="@gate.Value">@gate.Text</option>
                            }
                        </select>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="IngateInput.Notes" class="form-label-custom">Notes</label>
                        <textarea asp-for="IngateInput.Notes" class="form-input-custom" rows="3"></textarea>
                    </div>
                </div>

                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn-cancel-neutral" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-custom">Confirm Ingate</button>
                </div>
            </form>
        </div>
    </div>
</div>