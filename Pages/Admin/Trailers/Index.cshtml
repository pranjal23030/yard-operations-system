@page
@using YardOps.Pages.Admin.Trailers
@model IndexModel
@{
    ViewData["Title"] = "Trailers";
    ViewData["PageHeader"] = "Trailer Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/trailers.css" asp-append-version="true" />
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-info-circle me-2"></i>@TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="trailer-header-card">
    <div class="trailer-header-content">
        <div class="trailer-header-icon"><i class="fa-solid fa-truck"></i></div>
        <div class="trailer-header-text">
            <h1 class="trailer-title">All Trailers</h1>
            <p class="trailer-subtitle">Manage trailer master data (carrier, driver, goods, and status).</p>
        </div>
    </div>

    <div class="header-actions">
        <div class="dropdown">
            <button class="btn-export dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="fa-solid fa-download me-1"></i>Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-page-handler="ExportPdf"><i class="fa-solid fa-file-pdf me-2"></i>PDF</a></li>
            </ul>
        </div>

        <button type="button" class="btn-add-trailer" data-bs-toggle="modal" data-bs-target="#createTrailerModal">
            <i class="fa-solid fa-plus me-1"></i>Add Trailer
        </button>
    </div>
</div>

<form method="get" id="filterForm">
    <input type="hidden" name="PageNumber" value="1" />
    <div class="filters-row">
        <div class="search-box">
            <i class="fa-solid fa-search search-icon"></i>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
                   placeholder="Search by Trailer ID, Driver, or Carrier..." onchange="this.form.submit()" />
        </div>

        <div class="filter-dropdown-wrapper">
            <select name="StatusFilter" class="filter-select" onchange="this.form.submit()">
                @foreach (var status in Model.StatusOptions)
                {
                    var isSelected = Model.StatusFilter == status.Value || (string.IsNullOrEmpty(Model.StatusFilter) && status.Value == "all");
                    <option value="@status.Value" selected="@isSelected">@status.Text</option>
                }
            </select>
        </div>

        <div class="filter-dropdown-wrapper">
            <select name="LocationFilter" class="filter-select" onchange="this.form.submit()">
                @foreach (var loc in Model.LocationOptions)
                {
                    var isSelected = Model.LocationFilter == loc.Value || (string.IsNullOrEmpty(Model.LocationFilter) && loc.Value == "all");
                    <option value="@loc.Value" selected="@isSelected">@loc.Text</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="users-table">
    <table>
        <thead>
            <tr>
                <th>Trailer ID</th>
                <th>Carrier</th>
                <th>Driver</th>
                <th>Goods</th>
                <th>Status</th>
                <th>Location</th>
                <th>Arrival</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Trailers.Any())
            {
                @foreach (var trailer in Model.Trailers)
                {
                    <tr>
                        <td data-label="Trailer ID"><span class="trailer-code">@trailer.TrailerCode</span></td>
                        <td data-label="Carrier">@trailer.CarrierName</td>
                        <td data-label="Driver">@((trailer.DriverName ?? "—"))</td>
                        <td data-label="Goods">@trailer.GoodsSummary</td>
                        <td data-label="Status"><span class="status-badge @trailer.StatusBadgeClass">@trailer.CurrentStatus</span></td>
                        <td data-label="Location">@trailer.LocationName</td>
                        <td data-label="Arrival">@(trailer.ArrivalTime?.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt") ?? "—")</td>
                        <td data-label="Actions">
                            <div class="dropdown">
                                <button class="action-btn" type="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end action-dropdown">
                                    <li>
                                        <a class="dropdown-item action-item" href="#"
                                           data-bs-toggle="modal" data-bs-target="#viewTrailerModal"
                                           data-trailer-id="@trailer.TrailerId">
                                            <i class="fa-solid fa-eye me-2"></i>View
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item action-item" href="#"
                                           data-bs-toggle="modal" data-bs-target="#editTrailerModal"
                                           data-trailer-id="@trailer.TrailerId">
                                            <i class="fa-solid fa-pen-to-square me-2"></i>Edit
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item action-item-delete" href="#"
                                           data-bs-toggle="modal" data-bs-target="#deleteTrailerModal"
                                           data-trailer-id="@trailer.TrailerId"
                                           data-trailer-code="@trailer.TrailerCode">
                                            <i class="fa-solid fa-trash me-2"></i>Delete
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-truck fa-3x mb-3 d-block"></i>
                        No trailers found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="pagination-footer">
    <div class="pagination-info">
        @{
            var startItem = Model.TotalTrailers == 0 ? 0 : ((Model.CurrentPage - 1) * 10) + 1;
            var endItem = Math.Min(Model.CurrentPage * 10, Model.TotalTrailers);
        }
        Showing @startItem to @endItem of @Model.TotalTrailers trailers
    </div>
    <div class="pagination-controls">
        @if (Model.CurrentPage > 1)
        {
            <a href="?PageNumber=@(Model.CurrentPage - 1)&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-left"></i></button>
        }

        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            if (i == Model.CurrentPage)
            {
                <button class="page-btn active">@i</button>
            }
            else
            {
                <a href="?PageNumber=@i&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn">@i</a>
            }
        }

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="?PageNumber=@(Model.CurrentPage + 1)&SearchTerm=@Model.SearchTerm&StatusFilter=@Model.StatusFilter&LocationFilter=@Model.LocationFilter" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
        }
        else
        {
            <button class="page-btn" disabled><i class="fa-solid fa-chevron-right"></i></button>
        }
    </div>
</div>

<partial name="_Partials/_CreateTrailerModal" model="Model" />
<partial name="_Partials/_EditTrailerModal" model="Model" />
<partial name="_Partials/_ViewTrailerModal" model="Model" />
<partial name="_Partials/_DeleteTrailerModal" model="Model" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_Partials/_TrailerScripts" model="Model" />
}