@page
@model YardOps.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["PageHeader"] = "Admin Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="dash-grid">
    <section class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label">Total Users</div>
            <div class="kpi-value">@Model.TotalUsers</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Pending Email Verifications</div>
            <div class="kpi-value">@Model.PendingEmailVerifications</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Carriers</div>
            <div class="kpi-value">@Model.TotalCarriers</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Locations</div>
            <div class="kpi-value">@Model.TotalLocations</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Trailers</div>
            <div class="kpi-value">@Model.TotalTrailers</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">In-Yard Trailers</div>
            <div class="kpi-value">@Model.InYardTrailers</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Checked Out Today</div>
            <div class="kpi-value">@Model.CheckedOutToday</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Gate Activity Today</div>
            <div class="kpi-value">@Model.TodayIngates / @Model.TodayOutgates</div>
            <div class="kpi-sub">Ingate / Outgate</div>
        </div>
    </section>

    <section class="content-grid">
        <div class="panel">
            <h3 class="panel-title">Trailer Status Distribution</h3>
            <div class="chart-wrap chart-wrap-sm">
                <canvas id="statusChart"></canvas>
            </div>

            <div class="status-list">
                @foreach (var s in Model.StatusBreakdown)
                {
                    <div class="status-item">
                        <span>@s.Status</span>
                        <strong>@s.Count</strong>
                    </div>
                }
            </div>
        </div>

        <div class="panel">
            <h3 class="panel-title">Gate Trend (Last 7 Days)</h3>
            <div class="chart-wrap chart-wrap-md">
                <canvas id="trendChart"></canvas>
            </div>
        </div>

        <div class="side-stack">
            <div class="panel">
                <h3 class="panel-title">Quick Links</h3>
                <div class="quick-links quick-links-single">
                    <a asp-page="/Admin/Users/Index" class="quick-link">
                        <i class="fa-solid fa-users me-2"></i>Users
                    </a>
                    <a asp-page="/Admin/Trailers/Index" class="quick-link">
                        <i class="fa-solid fa-truck me-2"></i>Trailers
                    </a>
                    <a asp-page="/Admin/Locations/Index" class="quick-link">
                        <i class="fa-solid fa-map-location-dot me-2"></i>Locations
                    </a>
                </div>
            </div>

            <div class="panel">
                <h3 class="panel-title">Recent Activity</h3>
                @if (Model.RecentActivities.Any())
                {
                    <ul class="activity-list">
                        @foreach (var a in Model.RecentActivities)
                        {
                            <li class="activity-item">
                                <div class="activity-head">
                                    <span class="activity-action">@a.Action</span>
                                    <span class="activity-time">@a.OccurredOn.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</span>
                                </div>
                                <div class="activity-desc">@a.Description</div>
                                <div class="activity-actor">By @a.Actor</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No recent activity available.</p>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusLabels = @Html.Raw(Model.StatusChartLabelsJson);
        const statusData = @Html.Raw(Model.StatusChartDataJson);
        const trendLabels = @Html.Raw(Model.TrendLabelsJson);
        const ingates = @Html.Raw(Model.TrendIngatesJson);
        const outgates = @Html.Raw(Model.TrendOutgatesJson);

        const statusCtx = document.getElementById('statusChart');
        if (statusCtx) {
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusData,
                        backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#6b7280'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '60%',
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        }

        const trendCtx = document.getElementById('trendChart');
        if (trendCtx) {
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: trendLabels,
                    datasets: [
                        { label: 'Ingate', data: ingates, borderColor: '#0ea5e9', backgroundColor: 'rgba(14,165,233,0.12)', tension: 0.35, fill: true },
                        { label: 'Outgate', data: outgates, borderColor: '#22c55e', backgroundColor: 'rgba(34,197,94,0.10)', tension: 0.35, fill: true }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
        }
    </script>
}