@model YardOps.Pages.Admin.Locations.IndexModel

<!-- Edit Location Modal -->
<div class="modal fade" id="editLocationModal" tabindex="-1" aria-labelledby="editLocationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="editLocationModalLabel">Edit Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Edit">
                <div class="modal-body modal-body-custom">
                    <input type="hidden" asp-for="EditInput.LocationId" id="editLocationId" />
                    <input type="hidden" asp-for="EditInput.LocationType" id="editLocationType" />

                    <!-- Location Type (Read-only) -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Location Type</label>
                        <input type="text" id="editLocationTypeDisplay" class="form-input-custom input-disabled" readonly />
                    </div>

                    <!-- Location Name -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Location Name <span class="text-danger">*</span></label>
                        <input type="text" asp-for="EditInput.LocationName" id="editLocationName" 
                               class="form-input-custom" required maxlength="50" />
                        <span asp-validation-for="EditInput.LocationName" class="validation-error-custom"></span>
                    </div>

                    <!-- Capacity (shown only for Zone and Dock) -->
                    <div class="form-group-custom" id="editCapacityGroup" style="display: none;">
                        <label class="form-label-custom">Capacity <span class="text-danger">*</span></label>
                        <input type="number" asp-for="EditInput.Capacity" id="editLocationCapacity"
                               class="form-input-custom" min="1" max="1000" />
                        <span class="form-text text-muted small">Maximum number of trailers this location can hold</span>
                        <span asp-validation-for="EditInput.Capacity" class="validation-error-custom"></span>
                    </div>

                    <!-- Status -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Status</label>
                        <select asp-for="EditInput.Status" id="editLocationStatus" class="form-select-custom">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Maintenance">Maintenance</option>
                        </select>
                    </div>

                    <!-- Description -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Description</label>
                        <textarea asp-for="EditInput.Description" id="editLocationDescription" 
                                  class="form-input-custom" rows="2" maxlength="200"></textarea>
                        <span asp-validation-for="EditInput.Description" class="validation-error-custom"></span>
                    </div>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn-cancel-neutral" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-custom">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>