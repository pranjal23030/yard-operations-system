@model YardOps.Pages.Admin.Locations.IndexModel

<!-- Create Location Modal -->
<div class="modal fade" id="createLocationModal" tabindex="-1" aria-labelledby="createLocationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="createLocationModalLabel">Add New Location</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body modal-body-custom">
                    <!-- Location Type -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Location Type <span class="text-danger">*</span></label>
                        <select asp-for="Input.LocationType" class="form-select-custom" id="createLocationType" required>
                            <option value="">Select type...</option>
                            <option value="Zone">Zone</option>
                            <option value="Slot">Slot</option>
                            <option value="Dock">Dock</option>
                            <option value="Gate">Gate</option>
                        </select>
                        <span asp-validation-for="Input.LocationType" class="validation-error-custom"></span>
                    </div>

                    <!-- Location Name -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Location Name <span class="text-danger">*</span></label>
                        <input type="text" asp-for="Input.LocationName" class="form-input-custom"
                               placeholder="e.g., Zone A, Slot A-01, Dock 1" required maxlength="50" />
                        <span asp-validation-for="Input.LocationName" class="validation-error-custom"></span>
                    </div>

                    <!-- Capacity (shown only for Zone) -->
                    <div class="form-group-custom" id="createCapacityGroup" style="display: none;">
                        <label class="form-label-custom">Capacity <span class="text-danger">*</span></label>
                        <input type="number" asp-for="Input.Capacity" class="form-input-custom"
                               placeholder="Enter capacity" min="1" max="1000" />
                        <span class="form-text text-muted small">Maximum number of trailers this location can hold</span>
                        <span asp-validation-for="Input.Capacity" class="validation-error-custom"></span>
                    </div>

                    <!-- Status -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Status</label>
                        <select asp-for="Input.Status" class="form-select-custom">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Maintenance">Maintenance</option>
                        </select>
                    </div>

                    <!-- Description -->
                    <div class="form-group-custom">
                        <label class="form-label-custom">Description</label>
                        <textarea asp-for="Input.Description" class="form-input-custom" 
                                  placeholder="Optional description..." rows="2" maxlength="200"></textarea>
                        <span asp-validation-for="Input.Description" class="validation-error-custom"></span>
                    </div>
                </div>

                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn-cancel-neutral" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-custom">Create Location</button>
                </div>
            </form>
        </div>
    </div>
</div>